generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Conversation {
  id        Int       @id @default(autoincrement())
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  messages  Message[]
}

model Message {
  id             Int          @id @default(autoincrement())
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
}
model QuranVerse {
  id Int @id @default(autoincrement())
  surahNumber Int
  surahName String
  ayahNumber Int
  arabicText String
  translation String
}